---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <!-- Navbar -->
  <nav class="landing-nav">
    <div class="nav-inner">
      <div class="nav-brand">
        <div class="brand-icon">♟</div>
        <span class="brand-name">ReperTREE</span>
        <span class="brand-tag">AI</span>
      </div>
      <div class="nav-links">
        <a href="#features">Funcionalidades</a>
        <a href="#how">Cómo funciona</a>
        <a href="#stack">Tecnología</a>
      </div>
      <button id="langToggle" class="nav-toggle nav-toggle-lang">ES</button>
      <button id="themeToggle" class="nav-toggle nav-toggle-theme">☾</button>
      <a href="/app" class="nav-cta">Abrir App</a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <span class="hero-badge" data-i18n="hero-badge">Explorador de Aperturas con IA</span>
      <h1 class="hero-title" data-i18n="hero-title">Domina tus aperturas de ajedrez con inteligencia artificial</h1>
      <p class="hero-sub" data-i18n="hero-sub">Importa tus partidas de Lichess, analiza tu repertorio con Claude AI y Stockfish, y descubre lagunas en tus variantes favoritas.</p>
      <div class="hero-actions">
        <a href="/app" class="btn-hero-primary" data-i18n="btn-primary">Comenzar ahora &rarr;</a>
        <a href="#features" class="btn-hero-secondary" data-i18n="btn-secondary">Ver funcionalidades</a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="features" id="features">
    <div class="features-inner">
      <div class="feature-card">
        <div class="feature-icon">♞</div>
        <h3 class="feature-title" data-i18n="feature-1-title">Importación de Lichess</h3>
        <p class="feature-desc" data-i18n="feature-1-desc">Importa hasta 5,000 partidas de tu perfil de Lichess con un solo clic. Filtra por color, tipo de partida y más.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">✦</div>
        <h3 class="feature-title" data-i18n="feature-2-title">Análisis con Claude AI</h3>
        <p class="feature-desc" data-i18n="feature-2-desc">Recibe consejos estratégicos, detecta lagunas en tu repertorio y obtén recomendaciones de nuevas líneas con IA.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">⚡</div>
        <h3 class="feature-title" data-i18n="feature-3-title">Motor Stockfish</h3>
        <p class="feature-desc" data-i18n="feature-3-desc">Evaluación en tiempo real de posiciones con Stockfish integrado directamente en tu navegador via Web Worker.</p>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="how" id="how">
    <div class="how-inner">
      <h2 class="section-title" data-i18n="how-title">Cómo funciona</h2>
      <div class="steps">
        <div class="step">
          <div class="step-num">1</div>
          <h4 class="step-title" data-i18n="step-1-title">Importa tus partidas</h4>
          <p class="step-desc" data-i18n="step-1-desc">Conecta tu usuario de Lichess e importa tus partidas clasificadas. El sistema analiza las primeras 20 jugadas de cada partida.</p>
        </div>
        <div class="step">
          <div class="step-num">2</div>
          <h4 class="step-title" data-i18n="step-2-title">Explora tu repertorio</h4>
          <p class="step-desc" data-i18n="step-2-desc">Navega el árbol de aperturas con estadísticas de victorias, derrotas y tablas. Ve qué líneas juegas más y cuáles evitas.</p>
        </div>
        <div class="step">
          <div class="step-num">3</div>
          <h4 class="step-title" data-i18n="step-3-title">Mejora con IA</h4>
          <p class="step-desc" data-i18n="step-3-desc">Claude AI analiza tu repertorio, encuentra variantes débiles y sugiere mejoras personalizadas para tu estilo de juego.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="stack" id="stack">
    <div class="stack-inner">
      <h2 class="section-title" data-i18n="tech-title">Tecnología</h2>
      <div class="tech-grid">
        <div class="tech-item">
          <span class="tech-name">Astro</span>
          <span class="tech-role" data-i18n="tech-role-1">Framework</span>
        </div>
        <div class="tech-item">
          <span class="tech-name">Claude AI</span>
          <span class="tech-role" data-i18n="tech-role-2">Análisis IA</span>
        </div>
        <div class="tech-item">
          <span class="tech-name">Stockfish</span>
          <span class="tech-role" data-i18n="tech-role-3">Motor de ajedrez</span>
        </div>
        <div class="tech-item">
          <span class="tech-name">Lichess API</span>
          <span class="tech-role" data-i18n="tech-role-4">Importación</span>
        </div>
        <div class="tech-item">
          <span class="tech-name">Vercel</span>
          <span class="tech-role" data-i18n="tech-role-5">Hosting</span>
        </div>
        <div class="tech-item">
          <span class="tech-name">TypeScript</span>
          <span class="tech-role" data-i18n="tech-role-6">Lenguaje</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="landing-footer">
    <div class="footer-inner">
      <span class="footer-copy" data-i18n="footer-copy">&copy; 2026 JEREMY VILLEGAS.</span>
      <div class="footer-icons">
        <a href="mailto:Jrodriguez118910511@gmail.com" class="footer-icon" aria-label="Email" target="_blank">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="4" width="20" height="16" rx="2"></rect>
            <path d="m22 4-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 4"></path>
          </svg>
        </a>
        <a href="https://www.linkedin.com/in/jeremy-alejandro-villegas-rodriguez" class="footer-icon" aria-label="LinkedIn" target="_blank">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"></path>
            <circle cx="4" cy="4" r="2"></circle>
          </svg>
        </a>
        <a href="https://github.com/Villegas2003" class="footer-icon" aria-label="GitHub" target="_blank">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
          </svg>
        </a>
        <a href="https://wa.me/71166473" class="footer-icon" aria-label="WhatsApp" target="_blank">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M21.75 11.75a10 10 0 0 1-10 10h-.5a10 10 0 1 1 9.5-14.4"></path>
            <path d="M7.26 15.75c1.2 1.2 2.86 2 4.74 2 3.87 0 7-3.13 7-7s-3.13-7-7-7c-3.23 0-5.93 2.2-6.72 5.19m2.26 5.31l-1.6.53.53-1.6 3-3" stroke="currentColor" stroke-width="1.5"></path>
          </svg>
        </a>
      </div>
    </div>
  </footer>
</BaseLayout>

<style is:global>
  /* ── Landing Navbar ─────────────────────────── */
  .landing-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(12, 14, 18, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 32px;
    height: 64px;
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 18px;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .brand-icon {
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: linear-gradient(135deg, var(--accent), #d4860a);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    box-shadow: 0 2px 10px rgba(232, 168, 56, 0.3);
  }

  .brand-name {
    background: linear-gradient(135deg, var(--accent), #f0c866);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .brand-tag {
    font-size: 9px;
    font-weight: 600;
    color: var(--bg-0);
    background: var(--accent);
    padding: 2px 6px;
    border-radius: 4px;
    letter-spacing: 0.04em;
    margin-left: -6px;
  }

  .nav-links {
    display: flex;
    gap: 8px;
    margin-left: auto;
  }

  .nav-links a {
    padding: 8px 16px;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-2);
    text-decoration: none;
    transition: all 150ms ease;
  }

  .nav-links a:hover {
    color: var(--text-0);
    background: var(--bg-3);
    text-decoration: none;
  }

  .nav-cta {
    padding: 9px 22px;
    background: linear-gradient(135deg, var(--accent), #d4920a);
    color: var(--bg-0) !important;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none !important;
    box-shadow: 0 2px 12px rgba(232, 168, 56, 0.25);
    transition: all 150ms ease;
  }

  .nav-cta:hover {
    box-shadow: 0 4px 20px rgba(232, 168, 56, 0.4);
    transform: translateY(-1px);
  }

  .nav-toggle {
    padding: 8px 14px;
    border: 1px solid var(--border);
    border-radius: 100px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-2);
    background: transparent;
    transition: all 150ms ease;
    cursor: pointer;
  }

  .nav-toggle:hover {
    border-color: var(--border-h);
    color: var(--text-0);
    background: var(--bg-3);
  }

  .nav-toggle-theme {
    width: 36px;
    height: 36px;
    padding: 0;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
  }

  /* ── Hero ───────────────────────────────────── */
  .hero {
    padding: 140px 32px 60px;
    text-align: center;
    background: radial-gradient(ellipse at 50% 0%, rgba(232, 168, 56, 0.06) 0%, transparent 60%);
  }

  .hero-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .hero-badge {
    display: inline-block;
    padding: 6px 18px;
    border: 1px solid rgba(232, 168, 56, 0.3);
    border-radius: 100px;
    font-size: 13px;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.02em;
    margin-bottom: 28px;
    background: rgba(232, 168, 56, 0.06);
  }

  .hero-title {
    font-size: 48px;
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--text-0);
    margin-bottom: 20px;
  }

  .hero-sub {
    font-size: 18px;
    line-height: 1.7;
    color: var(--text-2);
    max-width: 560px;
    margin: 0 auto 36px;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-hero-primary {
    padding: 14px 32px;
    background: linear-gradient(135deg, var(--accent), #d4920a);
    color: var(--bg-0) !important;
    border-radius: 10px;
    font-size: 16px;
    font-weight: 700;
    text-decoration: none !important;
    box-shadow: 0 4px 20px rgba(232, 168, 56, 0.3);
    transition: all 200ms ease;
  }

  .btn-hero-primary:hover {
    box-shadow: 0 6px 28px rgba(232, 168, 56, 0.45);
    transform: translateY(-2px);
  }

  .btn-hero-secondary {
    padding: 14px 32px;
    border: 1px solid var(--border);
    border-radius: 10px;
    font-size: 16px;
    font-weight: 600;
    color: var(--text-1) !important;
    text-decoration: none !important;
    transition: all 200ms ease;
    background: transparent;
  }

  .btn-hero-secondary:hover {
    border-color: var(--border-h);
    background: var(--bg-3);
    color: var(--text-0) !important;
  }

  /* ── Features ───────────────────────────────── */
  .features {
    padding: 48px 32px 64px;
  }

  .features-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .feature-card {
    background: var(--bg-1);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 32px 28px;
    transition: all 200ms ease;
  }

  .feature-card:hover {
    border-color: var(--border-h);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
  }

  .feature-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: var(--accent-dim);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    margin-bottom: 20px;
  }

  .feature-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-0);
    margin-bottom: 10px;
  }

  .feature-desc {
    font-size: 14px;
    line-height: 1.7;
    color: var(--text-2);
  }

  /* ── How it works ───────────────────────────── */
  .how {
    padding: 64px 32px;
    background: var(--bg-1);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .how-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-title {
    font-size: 32px;
    font-weight: 800;
    color: var(--text-0);
    text-align: center;
    margin-bottom: 48px;
    letter-spacing: -0.02em;
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .step {
    text-align: center;
  }

  .step-num {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), #d4920a);
    color: var(--bg-0);
    font-size: 18px;
    font-weight: 800;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 18px;
    box-shadow: 0 4px 16px rgba(232, 168, 56, 0.25);
  }

  .step-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--text-0);
    margin-bottom: 10px;
  }

  .step-desc {
    font-size: 14px;
    line-height: 1.7;
    color: var(--text-2);
  }

  /* ── Tech Stack ─────────────────────────────── */
  .stack {
    padding: 64px 32px;
  }

  .stack-inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .tech-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .tech-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 24px 16px;
    background: var(--bg-1);
    border: 1px solid var(--border);
    border-radius: 12px;
    transition: all 200ms ease;
  }

  .tech-item:hover {
    border-color: var(--accent);
    background: var(--bg-2);
  }

  .tech-name {
    font-size: 16px;
    font-weight: 700;
    color: var(--text-0);
    margin-bottom: 4px;
  }

  .tech-role {
    font-size: 12px;
    color: var(--text-3);
    font-weight: 500;
  }

  /* ── Footer ─────────────────────────────────── */
  .landing-footer {
    padding: 32px;
    background: var(--bg-1);
    border-top: 1px solid var(--border);
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-copy {
    font-size: 12px;
    color: var(--text-3);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .footer-icons {
    display: flex;
    gap: 12px;
  }

  .footer-icon {
    width: 36px;
    height: 36px;
    border: 1px solid var(--text-3);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-2);
    text-decoration: none;
    transition: all 150ms ease;
  }

  .footer-icon:hover {
    border-color: var(--text-0);
    color: var(--text-0);
    transform: translateY(-2px);
  }

  /* ── Responsive ─────────────────────────────── */
  @media (max-width: 768px) {
    .hero-title { font-size: 32px; }
    .hero-sub { font-size: 16px; }
    .features-inner { grid-template-columns: 1fr; }
    .steps { grid-template-columns: 1fr; gap: 24px; }
    .tech-grid { grid-template-columns: repeat(2, 1fr); }
    .nav-links { display: none; }
    .hero { padding: 130px 20px 80px; }
  }
</style>

<script>
  // Initialize theme on page load
  const savedTheme = localStorage.getItem('theme') || 'dark';
  document.documentElement.setAttribute('data-theme', savedTheme);
  const themeToggle = document.getElementById('themeToggle');
  if (themeToggle) {
    themeToggle.textContent = savedTheme === 'dark' ? '☾' : '☀';
  }

  // Translations object
  const translations = {
    es: {
      'hero-badge': 'Explorador de Aperturas con IA',
      'hero-title': 'Domina tus aperturas de ajedrez con inteligencia artificial',
      'hero-sub': 'Importa tus partidas de Lichess, analiza tu repertorio con Claude AI y Stockfish, y descubre lagunas en tus variantes favoritas.',
      'btn-primary': 'Comenzar ahora →',
      'btn-secondary': 'Ver funcionalidades',
      'feature-1-title': 'Importación de Lichess',
      'feature-1-desc': 'Importa hasta 5,000 partidas de tu perfil de Lichess con un solo clic. Filtra por color, tipo de partida y más.',
      'feature-2-title': 'Análisis con Claude AI',
      'feature-2-desc': 'Recibe consejos estratégicos, detecta lagunas en tu repertorio y obtén recomendaciones de nuevas líneas con IA.',
      'feature-3-title': 'Motor Stockfish',
      'feature-3-desc': 'Evaluación en tiempo real de posiciones con Stockfish integrado directamente en tu navegador via Web Worker.',
      'how-title': 'Cómo funciona',
      'step-1-title': 'Importa tus partidas',
      'step-1-desc': 'Conecta tu usuario de Lichess e importa tus partidas clasificadas. El sistema analiza las primeras 20 jugadas de cada partida.',
      'step-2-title': 'Explora tu repertorio',
      'step-2-desc': 'Navega el árbol de aperturas con estadísticas de victorias, derrotas y tablas. Ve qué líneas juegas más y cuáles evitas.',
      'step-3-title': 'Mejora con IA',
      'step-3-desc': 'Claude AI analiza tu repertorio, encuentra variantes débiles y sugiere mejoras personalizadas para tu estilo de juego.',
      'tech-title': 'Tecnología',
      'tech-role-1': 'Framework',
      'tech-role-2': 'Análisis IA',
      'tech-role-3': 'Motor de ajedrez',
      'tech-role-4': 'Importación',
      'tech-role-5': 'Hosting',
      'tech-role-6': 'Lenguaje',
      'footer-copy': '© 2026 JEREMY VILLEGAS.',
    },
    en: {
      'hero-badge': 'Chess Opening Explorer with AI',
      'hero-title': 'Master your chess openings with artificial intelligence',
      'hero-sub': 'Import your Lichess games, analyze your repertoire with Claude AI and Stockfish, and discover gaps in your favorite variations.',
      'btn-primary': 'Get started →',
      'btn-secondary': 'View features',
      'feature-1-title': 'Lichess Import',
      'feature-1-desc': 'Import up to 5,000 games from your Lichess profile with a single click. Filter by color, game type and more.',
      'feature-2-title': 'Claude AI Analysis',
      'feature-2-desc': 'Get strategic advice, detect gaps in your repertoire, and receive recommendations for new lines with AI.',
      'feature-3-title': 'Stockfish Engine',
      'feature-3-desc': 'Real-time position evaluation with Stockfish integrated directly in your browser via Web Worker.',
      'how-title': 'How it works',
      'step-1-title': 'Import your games',
      'step-1-desc': 'Connect your Lichess username and import your rated games. The system analyzes the first 20 moves of each game.',
      'step-2-title': 'Explore your repertoire',
      'step-2-desc': 'Navigate the opening tree with win, loss and draw statistics. See which lines you play most and which you avoid.',
      'step-3-title': 'Improve with AI',
      'step-3-desc': 'Claude AI analyzes your repertoire, finds weak variations and suggests personalized improvements for your playing style.',
      'tech-title': 'Technology',
      'tech-role-1': 'Framework',
      'tech-role-2': 'AI Analysis',
      'tech-role-3': 'Chess Engine',
      'tech-role-4': 'Import',
      'tech-role-5': 'Hosting',
      'tech-role-6': 'Language',
      'footer-copy': '© 2026 JEREMY VILLEGAS.',
    }
  };

  let currentLang = localStorage.getItem('lang') || 'es';
  const langToggle = document.getElementById('langToggle');

  // Update language toggle button
  if (langToggle) {
    langToggle.textContent = currentLang.toUpperCase();
  }

  // Function to update all translatable text
  function updateLanguage(lang) {
    const elements = document.querySelectorAll('[data-i18n]');
    elements.forEach(el => {
      const key = el.getAttribute('data-i18n');
      if (translations[lang] && translations[lang][key]) {
        el.textContent = translations[lang][key];
      }
    });
    currentLang = lang;
    localStorage.setItem('lang', lang);
    if (langToggle) {
      langToggle.textContent = lang.toUpperCase();
    }
  }

  // Language toggle event
  if (langToggle) {
    langToggle.addEventListener('click', () => {
      const newLang = currentLang === 'es' ? 'en' : 'es';
      updateLanguage(newLang);
    });
  }

  // Theme toggle event
  if (themeToggle) {
    themeToggle.addEventListener('click', () => {
      const currentTheme = document.documentElement.getAttribute('data-theme') || 'dark';
      const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', newTheme);
      localStorage.setItem('theme', newTheme);
      themeToggle.textContent = newTheme === 'dark' ? '☾' : '☀';
    });
  }
</script>
