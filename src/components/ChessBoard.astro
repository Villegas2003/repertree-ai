---
---

<div class="board-panel">
  <div class="opening-info">
    <div class="opening-dot"></div>
    <div>
      <div class="on-n" id="opN">Posición inicial</div>
      <div class="on-e" id="opE">Mueve una pieza para comenzar</div>
    </div>
  </div>

  <div class="board-area">
    <div class="eval-bar" id="evalBar">
      <div class="eval-label top" id="evTop">0.0</div>
      <div class="eval-white" id="evF" style="height:50%"></div>
      <div class="eval-label bot" id="evBot"></div>
    </div>
    <div class="rank-labels" id="rC"></div>
    <div class="board-wrap">
      <div id="bd"></div>
      <div class="file-labels" id="fR"></div>
    </div>
  </div>

  <div class="nav-row">
    <button class="nb" id="navStart" title="Inicio">⏮</button>
    <button class="nb" id="navBack" title="Atrás">◀</button>
    <button class="nb" id="navFwd" title="Adelante">▶</button>
    <button class="nb" id="navEnd" title="Final">⏭</button>
    <button class="nb ai-btn" id="navAnalyze">✦ Analizar</button>
  </div>
</div>

<style>
  .board-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 16px 20px;
    gap: 10px;
    flex-shrink: 0;
    background: var(--bg-1);
  }

  .opening-info {
    width: 100%;
    max-width: 486px;
    padding: 8px 14px;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .opening-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    box-shadow: 0 0 6px rgba(232, 168, 56, 0.4);
  }

  .on-n { font-size: 13px; font-weight: 600; color: var(--text-0); line-height: 1.3; }
  .on-e { font-size: 11px; color: var(--text-2); font-family: var(--font-mono); }

  .board-area { display: flex; gap: 0; align-items: stretch; }

  .eval-bar {
    width: 22px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: #333;
    position: relative;
    margin-right: 6px;
    box-shadow: inset 0 0 4px rgba(0, 0, 0, 0.5);
  }

  .eval-white {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(180deg, #e8e8e8, #d0d0d0);
    transition: height 0.5s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  .eval-label {
    position: absolute;
    z-index: 2;
    left: 0;
    right: 0;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 600;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.6);
    padding: 3px 0;
  }

  .eval-label.top { top: 2px; color: #ccc; }
  .eval-label.bot { bottom: 2px; color: #333; }

  .board-wrap { display: flex; flex-direction: column; }

  .rank-labels {
    display: flex;
    flex-direction: column;
    justify-content: space-around;
    width: 16px;
  }

  .rank-labels :global(span) {
    font-size: 9px;
    color: var(--text-3);
    text-align: center;
    font-weight: 600;
    font-family: var(--font-mono);
  }

  :global(#bd) {
    display: grid;
    grid-template-columns: repeat(8, 56px);
    width: 448px;
    height: 448px;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    border: 2px solid rgba(255, 255, 255, 0.06);
  }

  .file-labels {
    display: flex;
    width: 448px;
    margin-top: 3px;
  }

  .file-labels :global(span) {
    flex: 1;
    font-size: 9px;
    color: var(--text-3);
    text-align: center;
    font-weight: 600;
    font-family: var(--font-mono);
  }

  .nav-row {
    display: flex;
    gap: 5px;
    align-items: center;
  }

  .nb {
    width: 36px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg-3);
    color: var(--text-1);
    cursor: pointer;
    font-size: 14px;
    transition: all var(--transition);
    font-family: var(--font-body);
  }

  .nb:hover {
    background: var(--bg-4);
    border-color: var(--border-h);
    color: var(--text-0);
  }

  .nb:active { transform: scale(0.95); }

  .nb.ai-btn {
    width: auto;
    padding: 0 14px;
    background: var(--blue-dim);
    border-color: rgba(79, 143, 247, 0.25);
    color: var(--blue);
    font-size: 12px;
    font-weight: 600;
    gap: 4px;
  }

  .nb.ai-btn:hover {
    background: rgba(79, 143, 247, 0.2);
    border-color: rgba(79, 143, 247, 0.4);
  }
</style>
