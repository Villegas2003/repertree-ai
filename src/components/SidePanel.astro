---
---

<div class="side-panel">
  <div class="tab-bar">
    <button class="tab-btn on" data-t="moves"><span class="tab-icon">📋</span> Movimientos</button>
    <button class="tab-btn" data-t="rep"><span class="tab-icon">📚</span> Repertorio</button>
    <button class="tab-btn" data-t="ai"><span class="tab-icon">✦</span> IA Claude</button>
    <button class="tab-btn" data-t="lic"><span class="tab-icon">♞</span> Lichess</button>
    <button class="tab-btn" data-t="tree"><span class="tab-icon">🌳</span> Árbol</button>
  </div>
  <div class="tab-content">
    <!-- Moves tab -->
    <div class="tab-pane on" id="tp-moves">
      <div class="explorer-section" id="explorerSection">
        <div class="section-label">Explorador de aperturas</div>
        <div id="explorerContent"></div>
      </div>
      <div class="exp-divider" id="expDivider" style="display:none"></div>
      <div class="section-label" id="movesLabel" style="display:none">Movimientos de la partida</div>
      <div id="mL"></div>
    </div>

    <!-- Repertoire tab -->
    <div class="tab-pane" id="tp-rep">
      <div class="color-selector">
        <div class="color-btn white on" id="selWhite">♔ Blancas</div>
        <div class="color-btn black" id="selBlack">♚ Negras</div>
      </div>
      <div class="action-row">
        <button class="btn-primary" id="addLineBtn">+ Agregar línea</button>
        <button class="btn-secondary" id="expRepBtn">↓ Exportar</button>
        <button class="btn-secondary" id="impRepBtn">↑ Importar</button>
        <input type="file" id="rF" style="display:none" accept=".json">
      </div>
      <div class="section-label">Líneas guardadas (<span id="lC">0</span>)</div>
      <div id="rL"></div>
    </div>

    <!-- AI tab -->
    <div class="tab-pane" id="tp-ai">
      <div class="ai-card">
        <div class="ai-card-header">
          <div class="ai-card-icon" style="background:var(--accent-dim);color:var(--accent)">🔑</div>
          <div class="ai-card-title">API Key de Anthropic</div>
        </div>
        <input type="password" class="form-input" id="apiK" placeholder="sk-ant-api03-…">
        <div class="hint">Obtén tu key en <a href="https://console.anthropic.com" target="_blank">console.anthropic.com</a></div>
      </div>

      <div class="ai-card">
        <div class="ai-card-header">
          <div class="ai-card-icon" style="background:var(--purple-dim);color:var(--purple)">🧠</div>
          <div class="ai-card-title">Consejo estratégico</div>
        </div>
        <div class="ai-output" id="aiA">Ingresa tu API key y presiona "Analizar" para recibir análisis estratégico de la posición actual.</div>
        <button class="btn-primary full-width" id="analyzeBtn" style="margin-top:10px">✦ Analizar posición</button>
      </div>

      <div class="ai-card">
        <div class="ai-card-header">
          <div class="ai-card-icon" style="background:var(--blue-dim);color:var(--blue)">🔍</div>
          <div class="ai-card-title">Detectar lagunas</div>
        </div>
        <div class="ai-output" id="aiG">La IA revisará tu repertorio e identificará variantes no cubiertas.</div>
        <button class="btn-blue full-width" id="gapsBtn">🔍 Detectar lagunas en repertorio</button>
      </div>

      <div class="ai-card">
        <div class="ai-card-header">
          <div class="ai-card-icon" style="background:var(--green-dim);color:var(--green)">📈</div>
          <div class="ai-card-title">Recomendar líneas</div>
        </div>
        <div class="ai-output" id="aiR">La IA sugerirá nuevas aperturas y variantes para enriquecer tu repertorio.</div>
        <button class="btn-green full-width" id="recBtn">📈 Recomendar nuevas líneas</button>
      </div>
    </div>

    <!-- Lichess tab -->
    <div class="tab-pane" id="tp-lic">
      <div class="ai-card">
        <div class="ai-card-header">
          <div class="ai-card-icon" style="background:rgba(255,255,255,.06);color:var(--text-1)">♞</div>
          <div class="ai-card-title">Importar partidas de Lichess</div>
        </div>
        <div class="form-group"><label class="form-label">Usuario de Lichess</label><input type="text" class="form-input" id="lcU" placeholder="tu_usuario"></div>
        <div class="form-group"><label class="form-label">Número de partidas</label><select class="form-input" id="lcM"><option value="50" selected>50</option><option value="100">100</option><option value="200">200</option><option value="500">500</option><option value="1000">1000</option><option value="2000">2000</option><option value="5000">5000</option></select></div>
        <div style="display:flex;gap:8px">
          <div class="form-group" style="flex:1"><label class="form-label">Color</label><select class="form-input" id="lcC"><option value="both">Ambos</option><option value="white">Blancas</option><option value="black">Negras</option></select></div>
          <div class="form-group" style="flex:1"><label class="form-label">Tipo</label><select class="form-input" id="lcR"><option value="true">Clasificadas</option><option value="false">Todas</option></select></div>
        </div>
        <button class="btn-primary full-width" id="importLicBtn" style="margin-top:4px">♞ Importar partidas</button>
        <div class="progress-bar" id="pB"><div class="progress-fill" id="pF"></div></div>
        <div class="import-status" id="iS"></div>
      </div>
    </div>

    <!-- Tree tab -->
    <div class="tab-pane" id="tp-tree">
      <div class="section-label" style="margin-bottom:8px">Árbol de aperturas</div>
      <div class="hint" style="margin-bottom:10px">Clic en un nodo para cargar esa posición.</div>
      <div id="treeC"></div>
    </div>
  </div>
</div>

<style>
  .side-panel {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    min-width: 0;
    border-left: 1px solid var(--border);
  }

  .tab-bar {
    display: flex;
    background: var(--bg-1);
    border-bottom: 1px solid var(--border);
    padding: 0 6px;
    flex-shrink: 0;
    overflow-x: auto;
    gap: 1px;
  }

  .tab-btn {
    padding: 12px 16px;
    border: none;
    border-bottom: 2px solid transparent;
    background: transparent;
    color: var(--text-2);
    cursor: pointer;
    font-size: 13px;
    font-weight: 500;
    white-space: nowrap;
    transition: all var(--transition);
    font-family: var(--font-body);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .tab-btn:hover { color: var(--text-1); background: rgba(255, 255, 255, 0.03); }
  .tab-btn.on { color: var(--accent); border-bottom-color: var(--accent); font-weight: 600; }
  .tab-icon { font-size: 14px; opacity: 0.75; }
  .tab-btn.on .tab-icon { opacity: 1; }

  .tab-content { flex: 1; overflow-y: auto; padding: 20px 24px; }
  .tab-pane { display: none; }
  .tab-pane.on { display: block; }

  /* Section labels */
  .section-label {
    font-size: 11px;
    font-weight: 700;
    color: var(--text-2);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .section-label::after { content: ''; flex: 1; height: 1px; background: var(--border); opacity: 0.4; }

  /* Explorer */
  .exp-divider { height: 1px; background: var(--border); margin: 12px 0; opacity: 0.5; }

  /* Color selector */
  .color-selector { display: flex; gap: 8px; margin-bottom: 16px; }
  .color-btn {
    flex: 1;
    padding: 12px;
    border-radius: var(--radius);
    border: 2px solid var(--border);
    cursor: pointer;
    text-align: center;
    font-size: 13px;
    font-weight: 600;
    transition: all var(--transition);
  }
  .color-btn.white { background: rgba(240, 240, 240, 0.06); color: var(--text-1); }
  .color-btn.black { background: rgba(30, 30, 30, 0.4); color: var(--text-1); }
  .color-btn.on { border-color: var(--accent); box-shadow: 0 0 0 1px var(--accent), 0 2px 8px rgba(232, 168, 56, 0.15); }

  /* Action row */
  .action-row { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 16px; }

  /* Buttons */
  .btn-primary {
    padding: 10px 18px;
    background: linear-gradient(135deg, var(--accent), #d4920a);
    color: var(--bg-0);
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-weight: 700;
    font-size: 13px;
    font-family: var(--font-body);
    transition: all var(--transition);
    box-shadow: 0 2px 8px rgba(232, 168, 56, 0.2);
  }
  .btn-primary:hover { box-shadow: 0 3px 12px rgba(232, 168, 56, 0.35); transform: translateY(-1px); }
  .btn-primary:active { transform: translateY(0); }

  .btn-secondary {
    padding: 10px 18px;
    background: var(--bg-4);
    color: var(--text-1);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-size: 13px;
    font-family: var(--font-body);
    font-weight: 500;
    transition: all var(--transition);
  }
  .btn-secondary:hover { background: var(--bg-4); border-color: var(--border-h); color: var(--text-0); }

  .btn-blue {
    padding: 11px 18px;
    background: var(--blue-dim);
    color: var(--blue);
    border: 1px solid rgba(79, 143, 247, 0.2);
    border-radius: var(--radius);
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
    font-family: var(--font-body);
    transition: all var(--transition);
  }
  .btn-blue:hover { background: rgba(79, 143, 247, 0.18); border-color: rgba(79, 143, 247, 0.35); }

  .btn-green {
    padding: 11px 18px;
    background: var(--green-dim);
    color: var(--green);
    border: 1px solid rgba(61, 186, 108, 0.2);
    border-radius: var(--radius);
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
    font-family: var(--font-body);
    transition: all var(--transition);
  }
  .btn-green:hover { background: rgba(61, 186, 108, 0.18); border-color: rgba(61, 186, 108, 0.35); }

  .full-width { width: 100%; margin-top: 8px; }

  /* AI Cards */
  .ai-card {
    background: var(--bg-3);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 18px 20px;
    margin-bottom: 16px;
  }
  .ai-card-header { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
  .ai-card-icon {
    width: 32px; height: 32px; border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center; font-size: 16px;
  }
  .ai-card-title { font-size: 14px; font-weight: 600; color: var(--text-0); }
  .ai-output {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px 16px;
    font-size: 13px;
    line-height: 1.6;
    color: var(--text-1);
    min-height: 70px;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .ai-output.loading { color: var(--text-3); font-style: italic; }

  /* Forms */
  .form-group { margin-bottom: 14px; }
  .form-label { display: block; font-size: 12px; color: var(--text-2); margin-bottom: 6px; font-weight: 500; }
  .form-input {
    width: 100%;
    padding: 11px 14px;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-0);
    font-size: 13px;
    font-family: var(--font-body);
    transition: all var(--transition);
  }
  .form-input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(232, 168, 56, 0.12); }
  .form-input::placeholder { color: var(--text-3); }
  select.form-input { cursor: pointer; }

  .hint { font-size: 11px; color: var(--text-3); margin-top: 6px; }
  .hint a { color: var(--blue); text-decoration: none; }
  .hint a:hover { text-decoration: underline; }

  /* Progress */
  .progress-bar {
    width: 100%;
    height: 8px;
    background: var(--bg-2);
    border-radius: 6px;
    overflow: hidden;
    margin: 12px 0;
    display: none;
    border: 1px solid var(--border);
  }
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), #f0c866);
    border-radius: 6px;
    transition: width 0.3s;
  }
  .import-status { font-size: 13px; color: var(--text-2); margin-top: 8px; line-height: 1.6; }
</style>
